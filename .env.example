# ============================================
# Environment Configuration Template
# ============================================
# Sao chép file này thành .env và sửa giá trị của bạn

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Server
HOST=127.0.0.1
PORT=5000

# CORS Origins (comma-separated)
CORS_ORIGINS=*

# Models Path
CNN_MODEL_PATH=backend/models/cnn_model.h5
YOLO_MODEL_PATH=backend/models/yolo_model.pt

# Confidence Threshold
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# Upload Configuration
UPLOAD_FOLDER=backend/uploads
MAX_FILE_SIZE=16777216

# Image Settings
IMAGE_SIZE=224

# Tooth Classes (JSON format)
TOOTH_CLASSES='{"0": "Khỏe mạnh", "1": "Sâu nhẹ", "2": "Sâu vừa", "3": "Sâu nặng"}'

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
